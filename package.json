{
  "name": "marp-agent",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "postinstall": "patch-package && npm run submodule:build",
    "submodule:build": "npm --prefix vendor/marp-cli install && npm --prefix vendor/marp-cli run build",
    "theme:build": "tailwindcss -i themes/src/lab.css -o themes/lab.css",
    "theme:watch": "tailwindcss -i themes/src/lab.css -o themes/lab.css --watch",
    "dev:theme": "npm run theme:watch",
    "preview": "node scripts/marp-serve.js",
    "preview:overview": "node scripts/preview-overview.js",
    "preview:example": "node scripts/marp-serve.js decks/example/slide.md",
    "preview:overview:example": "node scripts/preview-overview.js decks/example/slide.md",
    "slide": "node scripts/marp-serve.js",
    "slide:overview": "node scripts/preview-overview.js",
    "slide:example": "node scripts/marp-serve.js decks/example/slide.md",
    "new": "node scripts/new-deck.js",
    "outline": "node scripts/generate-outline.js",
    "deck:validate": "node scripts/validate-deck.js",
    "test": "node scripts/run-node-tests.js",
    "test:scaffold": "node --test test/new-deck.test.js",
    "test:e2e": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "playwright:install": "playwright install chromium"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "volta": {
    "node": "25.6.0",
    "npm": "11.9.0"
  },
  "dependencies": {
    "@marp-team/marp-cli": "file:./vendor/marp-cli",
    "@tailwindcss/cli": "^4.1.18",
    "beautiful-mermaid": "^0.1.3",
    "mathjax": "^4.1.1",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "patch-package": "^8.0.1",
    "playwright": "^1.58.1",
    "prettier": "3.8.1"
  }
}
